# Runtime
AMNTV_PROJECTS=./projects
AMNTV_DRY_RUN=1
AMNTV_NO_OPEN=0

# Agent nodes
ANTHROPIC_API_KEY=

# MiniMax speech/video (real providers are never selected without a key)
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3

# ComfyUI image generation
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW=
COMFYUI_INPUT_DIR=

# Real video APIs need public HTTPS frame URLs. Configure an uploader that
# maps local selected frames to URLs before enabling MiniMax video.
AMNTV_FRAME_URL_MANIFEST=
